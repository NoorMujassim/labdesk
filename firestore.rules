rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function admin() {
      return signedIn() && (
        (exists(/databases/$(database)/documents/admin/config) && get(/databases/$(database)/documents/admin/config).data.adminUid == uid()) ||
        (exists(/databases/$(database)/documents/users/$(uid())) && get(/databases/$(database)/documents/users/$(uid())).data.isAdmin == true)
      );
    }
    function tenant(userId) { return signedIn() && uid() == userId; }
    function tenantCreate(userId) { return request.resource.data.labId == userId; }
    function tenantUpdate(userId) {
      return request.resource.data.labId == userId
        && (!('labId' in resource.data) || request.resource.data.labId == resource.data.labId);
    }
    function accountFieldsSafe() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasNone(['isAdmin', 'isApproved', 'approvedAt', 'plan', 'planStatus', 'planValidUntil']);
    }

    match /admin/{doc=**} { allow read, write: if admin(); }

    match /users/{userId} {
      allow get: if tenant(userId) || admin();
      allow list: if admin();
      allow create: if (tenant(userId) && tenantCreate(userId)
        && !request.resource.data.keys().hasAny(['isAdmin', 'isApproved'])) || admin();
      allow update: if (tenant(userId) && tenantUpdate(userId) && accountFieldsSafe()) || admin();
      allow delete: if tenant(userId) || admin();

      match /patients/{docId} {
        allow read, delete: if tenant(userId) || admin();
        allow create: if (tenant(userId) && tenantCreate(userId)) || admin();
        allow update: if (tenant(userId) && tenantUpdate(userId)) || admin();
      }
      match /reports/{docId} {
        allow read, delete: if tenant(userId) || admin();
        allow create: if (tenant(userId) && tenantCreate(userId)) || admin();
        allow update: if (tenant(userId) && tenantUpdate(userId)) || admin();
      }
      match /subscriptions/{docId} {
        allow read: if tenant(userId) || admin();
        allow write: if admin();
      }
      match /payments/{docId} {
        allow read: if tenant(userId) || admin();
        allow write: if admin();
      }
      match /{doc=**} { allow read, write: if false; }
    }

    match /pendingUsers/{userId} {
      allow create: if (tenant(userId) && request.resource.data.uid == userId) || admin();
      allow read: if tenant(userId) || admin();
      allow update, delete: if admin();
    }
    match /approvedUsers/{userId} {
      allow read: if tenant(userId) || admin();
      allow write: if admin();
    }
  }
}